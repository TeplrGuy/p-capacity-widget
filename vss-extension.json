{
  "manifestVersion": 1,
  "id": "p-capacity-widget",
  "publisher": "gappiah-msft-demo",
  "version": "1.0.8",
  "name": "Story Capacity Widget",
  "description": "Sprint Work Details capacity pane on a dashboard, reading Remaining Work from User Stories (no Tasks required). Per-developer and per-Activity load bars with a configurable iteration.",
  "public": true,
  "categories": ["Azure Boards"],
  "tags": ["capacity", "sprint", "dashboard", "user stories", "scrum", "agile", "remaining work", "work details"],
  "branding": { "color": "#0078D4", "theme": "dark" },
  "content": {
    "details": { "path": "README.md" },
    "license": { "path": "LICENSE" }
  },
  "links": {
    "home":       { "uri": "https://github.com/gappiah/p-capacity-widget" },
    "repository": { "uri": "https://github.com/gappiah/p-capacity-widget" },
    "issues":     { "uri": "https://github.com/gappiah/p-capacity-widget/issues" }
  },
  "targets": [
    { "id": "Microsoft.VisualStudio.Services" }
  ],
  "scopes": [
    "vso.work",
    "vso.profile",
    "vso.project"
  ],
  "icons": {
    "default": "static/icon.png"
  },
  "files": [
    { "path": "dist", "addressable": true },
    { "path": "static", "addressable": true },
    { "path": "README.md", "addressable": true },
    { "path": "LICENSE", "addressable": true }
  ],
  "contributions": [
    {
      "id": "story-capacity-widget",
      "type": "ms.vss-dashboards-web.widget",
      "targets": [
        "ms.vss-dashboards-web.widget-catalog",
        ".story-capacity-widget-config"
      ],
      "properties": {
        "name": "Story Capacity (Stories-only)",
        "description": "Per-developer and per-Activity load bars based on Story-level Remaining Work in an iteration.",
        "catalogIconUrl": "static/icon.png",
        "previewImageUrl": "static/icon.png",
        "uri": "dist/capacityWidget.html",
        "supportedSizes": [
          { "rowSpan": 1, "columnSpan": 1 },
          { "rowSpan": 1, "columnSpan": 2 },
          { "rowSpan": 1, "columnSpan": 3 },
          { "rowSpan": 1, "columnSpan": 4 },
